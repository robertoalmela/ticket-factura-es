NODE_ENV=production
PORT=8380
BASE_URL=https://ticketfactura.example.com
JWT_SECRET=cambia-esto-por-un-secreto-largo-aleatorio

# SQLite: usa una ruta dentro del volumen persistente del VPS.
DATA_DIR=/var/lib/ticketfactura
# DB_PATH=/var/lib/ticketfactura/ticketfactura.db

# Si la app esta detras de Nginx/Caddy/Traefik, normalmente 1.
TRUST_PROXY=1

# SMTP real para enviar facturas.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=usuario-smtp
SMTP_PASS=password-smtp
SMTP_FROM="TicketFactura <facturas@example.com>"

# Variables para crear un comercio con npm run commerce:create.
COMERCIO_NOMBRE="Copisteria Centro"
COMERCIO_NIF=B12345674
COMERCIO_DIRECCION="Calle Ejemplo 1, 03201 Elche"
COMERCIO_EMAIL=facturas@example.com
COMERCIO_SERIE=CC
COMERCIO_IVA_DEFECTO=21
COMERCIO_SECUENCIA_PREVIA=0
COMERCIO_ANIO_PREVIO=2026
